# Copy to .env and fill in to enable the daily email digest locally.
# In CI (GitHub Actions) set these as repo secrets instead — never commit real values.

# --- Claude API (optional: AI crude-impact sentiment via tools/enrich_sentiment.py) ---
# Get a key at https://console.anthropic.com/ . Uses Claude Haiku 4.5 (~$1/$5 per 1M tokens);
# a run over a few hundred headlines costs well under $0.05.
ANTHROPIC_API_KEY=sk-ant-...

# --- EIA petroleum data (optional: weekly inventories/production in the Markets tab) ---
# Free instant key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# --- Telegram alerts (optional: real-time push of high-impact stories) ---
# Create a bot via @BotFather, then message it once and get your chat id from
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SMTP for the daily digest email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-gmail-app-password   # Gmail: create at https://myaccount.google.com/apppasswords
DIGEST_TO=neil@sheerstockpark.com
DIGEST_FROM=your-address@gmail.com
